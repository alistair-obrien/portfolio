---
import { getEntry, render } from "astro:content";
import ToyLayout from "../../layouts/ToyLayout.astro";

const { slug } = Astro.params;
const entry = await getEntry("toys", slug as string);

if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
---

<ToyLayout
  title={entry.data.title}
  description={entry.data.description}
  startDate={entry.data.startDate}
  endDate={entry.data.endDate}
  image={entry.data.image}
  skills={entry.data.skills}
  demoLink={entry.data.demoLink}
  sourceLink={entry.data.sourceLink}
  widgetSrc={entry.data.widgetSrc}
  widgetHeight={entry.data.widgetHeight}
  fullscreenLink={entry.data.fullscreenLink}
>
  <Content />
</ToyLayout>
