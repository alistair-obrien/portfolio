---
import { getEntry, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";

// Get the slug from params and fetch the entry
const { slug } = Astro.params;

// Handle the slug (could be "welcome-post" or "guides/markdown-guide")
const entry = await getEntry("blog", slug as string);

// If entry doesn't exist, return 404
if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);

const readingSource = entry.body
  .replace(/```[\s\S]*?```/g, " ")
  .replace(/{%[\s\S]*?%}/g, " ")
  .replace(/<[^>]+>/g, " ");
const wordCount = readingSource.trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BlogLayout
  title={entry.data.title}
  description={entry.data.description}
  publishDate={entry.data.publishDate}
  updatedDate={entry.data.updatedDate}
  image={entry.data.image}
  tags={entry.data.tags}
  readingTime={readingTime}
>
  <Content />
</BlogLayout>
