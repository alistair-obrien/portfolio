---
import Layout from "../layouts/Layout.astro";
import RoguelikeBrowserDemo from "../components/game/RoguelikeBrowserDemo";
---

<Layout
  title="Roguelike Browser Widget"
  description="A React widget powered by the C# roguelike engine running directly in browser-local WebAssembly."
>
  <main class="bg-base-200 px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <section class="rounded-[2rem] border border-base-300 bg-base-100 p-4 shadow-sm">
        <RoguelikeBrowserDemo client:load />
      </section>
    </div>
  </main>
</Layout>
