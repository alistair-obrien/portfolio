---
import { Download, FileText, X } from "@lucide/astro";
import ResumeContent from "../content/resume/resume.md";
---

<button
  type="button"
  class="btn btn-primary mt-5 gap-2"
  onclick="document.getElementById('resume-modal')?.showModal()"
>
  <FileText class="size-5" />
  Resume
</button>

<dialog id="resume-modal" class="modal">
  <div
    class="modal-box flex max-h-[86vh] w-11/12 max-w-5xl flex-col overflow-hidden rounded-lg p-0 text-left"
  >
    <div
      class="flex shrink-0 items-start justify-between gap-3 border-b border-base-300 bg-base-100 px-5 py-4"
    >
      <div class="min-w-0">
        <h2 class="text-xl font-bold leading-tight">Alistair O'Brien</h2>
        <p class="text-sm text-base-content/70">
          Senior C# Internal Tools & Automation Engineer
        </p>
        <p class="mt-1 text-sm text-base-content/70">
          Osaka, Japan | Remote or Japan-based roles | Open to relocation |
          alistair.m.obrien@gmail.com |
          <a
            class="link link-primary"
            href="https://jp.linkedin.com/in/alistair-o-brien"
            target="_blank"
            rel="noopener noreferrer"
          >
            jp.linkedin.com/in/alistair-o-brien
          </a>
        </p>
      </div>
      <div class="flex shrink-0 items-center gap-2">
        <a
          class="btn btn-sm btn-primary gap-2"
          href="/alistair-obrien-resume.pdf"
          download="alistair-obrien-resume.pdf"
        >
          <Download class="size-4" />
          PDF
        </a>
        <form method="dialog">
          <button class="btn btn-sm btn-ghost btn-circle" aria-label="Close resume">
            <X class="size-5" />
          </button>
        </form>
      </div>
    </div>

    <article class="resume-document min-h-0 flex-1 overflow-y-auto bg-base-100 px-5 py-5 sm:px-8 sm:py-7">
      <ResumeContent />
    </article>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<style>
  :global(.resume-document) {
    background: var(--color-base-100);
    color: var(--color-base-content);
    font-size: 0.95rem;
    line-height: 1.55;
    text-align: left;
  }

  :global(.resume-document section) {
    margin-top: 1rem;
  }

  :global(.resume-document h2) {
    margin: 1rem 0 0.4rem;
    border-bottom: 1px solid color-mix(in oklch, currentColor 28%, transparent);
    padding-bottom: 0.2rem;
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  :global(.resume-document h3) {
    margin: 0.8rem 0 0.2rem;
    font-size: 1rem;
    font-weight: 800;
  }

  :global(.resume-document p) {
    margin: 0.25rem 0;
  }

  :global(.resume-document ul) {
    list-style: disc;
    margin: 0.35rem 0 0.65rem 1.2rem;
    padding: 0;
  }

  :global(.resume-document ul ul) {
    list-style: circle;
    margin-top: 0.15rem;
  }

  :global(.resume-document li) {
    margin: 0.2rem 0;
    padding-left: 0.1rem;
  }

  :global(.resume-document strong) {
    font-weight: 800;
  }

  :global(.resume-document .meta) {
    color: color-mix(in oklch, currentColor 72%, transparent);
    font-size: 0.9rem;
  }

  :global(.resume-document .subhead) {
    margin-top: 0.7rem;
    font-weight: 700;
  }
</style>
