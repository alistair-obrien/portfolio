---
import { getCollection } from "astro:content";
import ToolCard from "./ToolCard.astro";

const toolEntries = await getCollection("tools");

// Filter featured tools, sort by start date (most recent first), limit to 3
const featuredTools = toolEntries
  .filter((tool) => tool.data.featured === true)
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime())
  .slice(0, 3);
---

<section id="tools" class="py-20 px-4 bg-base-200">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold mb-4">Developed Tools</h2>
      <p class="text-lg text-base-content/70">
        A collection of tools I created for various projects in order to optimize workflow for various collaborators.
      </p>
    </div>

    {
      featuredTools.length === 0 ? (
        <div class="text-center py-12">
          <p class="text-lg text-base-content/60">
            No featured tools yet. Check out all tools below.
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredTools.map((tool) => (
            <ToolCard tool={tool} />
          ))}
        </div>
      )
    }

    <!--div class="text-center mt-10">
      <a href="/tools" class="btn btn-primary btn-outline">
        View All Tools
      </a>
    </div-->
  </div>
</section>
