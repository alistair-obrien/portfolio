---
import { Image } from "astro:assets";
import SkillBadge from "./SkillBadge.astro";
import PlatformBadge from "./PlatformBadge.astro";
import RoleBadge from "./RoleBadge.astro";
import { ExternalLink, Eye, X } from "@lucide/astro";
import { render, type CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const modalId = `project-modal-${project.id.replace(/[^a-zA-Z0-9_-]/g, "-")}`;

function formatPeriod(startDate: Date, endDate?: Date) {
  const options: Intl.DateTimeFormatOptions = {
    month: "short",
    year: "numeric",
  };
  const start = startDate.toLocaleDateString("en-US", options);
  const end = endDate
    ? endDate.toLocaleDateString("en-US", options)
    : "Present";
  return `${start} - ${end}`;
}
---

<article class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
  <button
    type="button"
    class="block w-full cursor-pointer border-0 bg-transparent p-0 text-left hover:opacity-80 transition-opacity"
    aria-controls={modalId}
    onclick={`document.getElementById('${modalId}').showModal()`}
  >
    <figure class="aspect-video">
      <Image
        src={project.data.image}
        alt={project.data.title}
        class="w-full h-full object-cover"
        width={600}
        height={400}
      />
    </figure>
  </button>
  <div class="card-body">
    <h3 class="card-title hover:text-primary transition-colors">
      <button
        type="button"
        class="cursor-pointer border-0 bg-transparent p-0 text-left font-[inherit] text-inherit"
        aria-controls={modalId}
        onclick={`document.getElementById('${modalId}').showModal()`}
      >
        {project.data.title}
      </button>
    </h3>
    <time class="text-sm text-base-content/60">
      {formatPeriod(project.data.startDate, project.data.endDate)}
    </time>
    <div class="flex flex-wrap gap-2 mt-2">
      {project.data.roles?.map((role) => <RoleBadge role={role} />)}
    </div>
    <p class="text-base-content/80">{project.data.description}</p>
    <div class="flex flex-wrap gap-2 mt-2">
      {project.data.skills.map((skill) => <SkillBadge skill={skill} />)}
    </div>
    <div class="flex flex-wrap gap-2 mt-2">
      {project.data.platforms?.map((platform) => <PlatformBadge platform={platform} />)}
    </div>
    <div class="card-actions justify-end mt-4 gap-2">
      {
        project.data.demoLink && (
          <a
            href={project.data.demoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm btn-soft gap-1"
          >
            <ExternalLink class="size-4" />
            Game Store Page
          </a>
        )
      }
      {
        project.data.sourceLink && (
          <a
            href={project.data.sourceLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm btn-soft gap-1"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 32 32"
              fill="currentColor"
            >
              <path d="M16,2.345c7.735,0,14,6.265,14,14-.002,6.015-3.839,11.359-9.537,13.282-.7,.14-.963-.298-.963-.665,0-.473,.018-1.978,.018-3.85,0-1.312-.437-2.152-.945-2.59,3.115-.35,6.388-1.54,6.388-6.912,0-1.54-.543-2.783-1.435-3.762,.14-.35,.63-1.785-.14-3.71,0,0-1.173-.385-3.85,1.435-1.12-.315-2.31-.472-3.5-.472s-2.38,.157-3.5,.472c-2.677-1.802-3.85-1.435-3.85-1.435-.77,1.925-.28,3.36-.14,3.71-.892,.98-1.435,2.24-1.435,3.762,0,5.355,3.255,6.563,6.37,6.913-.403,.35-.77,.963-.893,1.872-.805,.368-2.818,.963-4.077-1.155-.263-.42-1.05-1.452-2.152-1.435-1.173,.018-.472,.665,.017,.927,.595,.332,1.277,1.575,1.435,1.978,.28,.787,1.19,2.293,4.707,1.645,0,1.173,.018,2.275,.018,2.607,0,.368-.263,.787-.963,.665-5.719-1.904-9.576-7.255-9.573-13.283,0-7.735,6.265-14,14-14Z" />
            </svg>
            Source
          </a>
        )
      }
      <button
        type="button"
        class="btn btn-sm btn-primary gap-1"
        aria-controls={modalId}
        onclick={`document.getElementById('${modalId}').showModal()`}
      >
        <Eye class="size-4" />
        More Details
      </button>
    </div>
  </div>
</article>

<dialog id={modalId} class="modal p-4 sm:p-8">
  <div
    class="modal-box flex max-h-[calc(100dvh-2rem)] w-11/12 max-w-5xl flex-col overflow-hidden rounded-lg p-0 text-left sm:max-h-[calc(100dvh-4rem)] lg:max-h-[calc(100dvh-6rem)]"
  >
    <div
      class="flex shrink-0 items-start justify-between gap-4 border-b border-base-300 bg-base-100 px-5 py-4"
    >
      <div class="flex min-w-0 flex-wrap items-baseline gap-x-3 gap-y-1">
        <h3 class="text-xl font-bold leading-tight">{project.data.title}</h3>
        <time class="text-sm text-base-content/60 font-mono">
          {formatPeriod(project.data.startDate, project.data.endDate)}
        </time>
      </div>
      <div class="flex shrink-0 flex-wrap items-center justify-end gap-2">
        {project.data.demoLink && (
          <a
            href={project.data.demoLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm btn-soft gap-1"
          >
            Game Store Page
            <ExternalLink class="size-4" />
          </a>
        )}
        {project.data.sourceLink && (
          <a
            href={project.data.sourceLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-sm btn-ghost gap-2"
          >
            Source
            <ExternalLink class="size-4" />
          </a>
        )}
        <form method="dialog">
          <button
            class="btn btn-sm btn-ghost btn-circle"
            aria-label="Close project details"
          >
            <X class="size-5" />
          </button>
        </form>
      </div>
    </div>

    <article
      class="min-h-0 flex-1 overflow-y-auto [scrollbar-gutter:stable] px-5 py-5 sm:px-8 sm:py-7"
    >
      <div class="space-y-7">
        <figure class="overflow-hidden rounded-lg bg-base-200 shadow-sm">
          <Image
            src={project.data.image}
            alt={project.data.title}
            class="w-full aspect-video object-cover"
            width={1000}
            height={563}
          />
        </figure>

        <section class="space-y-4">
          <p class="max-w-3xl text-base leading-7 text-base-content/80">
            {project.data.description}
          </p>
        </section>

        <div class="space-y-3">
          {project.data.roles && project.data.roles.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {project.data.roles.map((role) => <RoleBadge role={role} />)}
            </div>
          )}

          <div class="flex flex-wrap gap-2">
            {project.data.skills.map((skill) => <SkillBadge skill={skill} />)}
          </div>

          {project.data.platforms && project.data.platforms.length > 0 && (
            <div class="flex flex-wrap gap-3 pt-1">
              {project.data.platforms.map((platform) => (
                <PlatformBadge platform={platform} />
              ))}
            </div>
          )}
        </div>

        <div class="border-t border-base-content/10 pt-7">
          <div
            class="prose prose-base max-w-none text-base-content/80 prose-headings:mt-10 prose-headings:mb-4 prose-h2:text-2xl prose-h3:text-xl prose-p:my-4 prose-p:leading-7"
          >
            <Content />
          </div>
        </div>
      </div>
    </article>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
