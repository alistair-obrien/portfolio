---
import { getCollection } from "astro:content";
import BlogCard from "./BlogCard.astro";
import { ArrowRight } from "@lucide/astro";

const blogEntries = await getCollection("blog");

// Sort by publish date, most recent first
const sortedPosts = blogEntries.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

// Get only the latest 3 posts
const latestPosts = sortedPosts.slice(0, 3);
---

<section id="blog" class="py-20 px-4 bg-base-300">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold mb-4">GenOSys Engine</h2>
      <div class="text-left mb-12">
        <p class="text-lg text-base-content/70 text-center mb-4 text-primary">
          Devlog and updates on the GenOSys Engine project, a cyberpunk roguelike Game Engine.
        </p>
        
        <p class="text-lg text-base-content/70">
        The engine is built with a pure C# backend. The frontend is built with Godot's UI framework and 2D Renderer.
        </p> 
        <p class="text-lg text-base-content/70">
          This is a long term personal project intended to learn and experiment with game engine architecture, procedural generation, and game development in general. 
        </p>
        <p class="text-lg text-base-content/70">
          The core engine is being built from scratch, focusing heavily on modability. The engine and the game are one and the same, keeping consistency and fast content iteration at the forefront. 
        </p>
        <p class="text-lg text-base-content/70">
          The blog will cover the development process, challenges faced, and insights gained along the way.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {latestPosts.map((post) => <BlogCard post={post} />)}
    </div>

    <div class="text-center mt-12">
      <a href="/blog" class="btn btn-primary gap-2">
        View All Posts
        <ArrowRight class="size-4" />
      </a>
    </div>
  </div>
</section>
