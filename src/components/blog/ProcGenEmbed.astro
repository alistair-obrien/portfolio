---
interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  src: string;
  height?: string;
  fullHeight?: boolean;
}

const {
  eyebrow,
  title,
  description,
  src,
  height = "44rem",
  fullHeight = false,
} = Astro.props;

const parsedUrl = new URL(src, "https://procgen.local");
const embedSearch = parsedUrl.search || "";
const storageKey = `procgen-embed:${parsedUrl.pathname}${embedSearch}`;
const hostId = `procgen-host-${storageKey.replace(/[^a-zA-Z0-9_-]+/g, "-")}`;
const widgetAssetVersion = Date.now().toString();
---

<link rel="stylesheet" href="/widgets/proc-gen/site.css" />

<div class:list={["not-prose", fullHeight ? "flex min-h-0 flex-1 flex-col overflow-hidden" : "my-10"]}>
  {(eyebrow || title || description) && (
    <div class="mb-4">
      {eyebrow && (
        <p class="m-0 text-xs font-semibold uppercase tracking-[0.22em] text-primary/80">
          {eyebrow}
        </p>
      )}
      {title && (
        <h3 class="m-0 mt-2 text-xl font-semibold text-base-content">
          {title}
        </h3>
      )}
      {description && (
        <p class="m-0 mt-2 max-w-3xl text-sm leading-6 text-base-content/70">
          {description}
        </p>
      )}
    </div>
  )}

  <div
    id={hostId}
    class:list={["procgen-inline-shell procgen-app", fullHeight && "procgen-inline-shell-full"]}
    style={fullHeight ? undefined : `--procgen-inline-height:${height}; height:min(var(--procgen-inline-height), 82svh);`}
  ></div>
</div>

<style is:global>
  .procgen-inline-shell {
    min-height: 20rem;
    max-height: 82svh;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  .procgen-inline-shell.procgen-app > .shell {
    width: 100% !important;
    height: 100% !important;
    min-height: 0 !important;
    max-height: 100% !important;
    padding: 0;
    overflow: hidden;
  }

  .procgen-inline-shell.procgen-app > .shell .controls,
  .procgen-inline-shell.procgen-app > .shell .viewport {
    min-height: 0;
    max-height: 100%;
  }

  .procgen-inline-shell.procgen-app > .shell .controls {
    overflow: auto;
  }

  .procgen-inline-shell.procgen-app > .shell .viewport {
    overflow: hidden;
  }

  .procgen-inline-shell-full.procgen-app > .shell .controls {
    overflow: auto;
  }

  .procgen-inline-shell-full.procgen-app > .shell .viewport {
    overflow: hidden;
  }

  .procgen-inline-shell-full.procgen-app > .shell .viewport-stage,
  .procgen-inline-shell-full.procgen-app > .shell .canvas-shell {
    min-height: 0 !important;
  }

  .procgen-inline-shell-full {
    display: flex;
    flex: 1 1 0;
    min-height: 0;
    height: 100%;
    max-height: 100%;
  }

  @media (max-width: 1024px) {
    .procgen-inline-shell:not(.procgen-inline-shell-full) {
      height: min(var(--procgen-inline-height, 44rem), 78svh) !important;
      min-height: 32rem;
      max-height: 78svh;
      overflow: hidden;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell {
      display: flex !important;
      flex-direction: column;
      height: 100% !important;
      min-height: 0 !important;
      max-height: 100% !important;
      overflow: hidden;
      width: 100% !important;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell > .panel {
      width: 100%;
      min-width: 0;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .viewport {
      flex: 0 0 14rem;
      min-height: 14rem;
      max-height: 14rem;
      overflow: hidden;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .controls {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      -webkit-overflow-scrolling: touch;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .viewport-stage,
    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .canvas-shell {
      width: 100% !important;
      height: 100% !important;
      min-height: 0 !important;
      min-width: 0 !important;
    }
  }

  @media (max-width: 720px) {
    .procgen-inline-shell:not(.procgen-inline-shell-full) {
      height: min(var(--procgen-inline-height, 44rem), 76svh) !important;
      min-height: 30rem;
      max-height: 76svh;
      overflow: hidden;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .viewport {
      flex: 0 0 13rem;
      min-height: 13rem;
      max-height: 13rem;
      overflow: hidden;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .controls {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      -webkit-overflow-scrolling: touch;
    }

    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .viewport-stage,
    .procgen-inline-shell:not(.procgen-inline-shell-full).procgen-app > .shell .canvas-shell {
      height: 100% !important;
      min-height: 0 !important;
    }
  }
</style>

<script define:vars={{ hostId, embedSearch, storageKey, widgetAssetVersion }} is:inline>
  (async () => {
    const host = document.getElementById(hostId);
    if (!host) {
      return;
    }

    const response = await fetch(`/widgets/proc-gen/index.html?v=${encodeURIComponent(widgetAssetVersion)}`, {
      cache: "no-store",
    });
    if (!response.ok) {
      throw new Error(`Failed to load ProcGen widget shell (HTTP ${response.status}).`);
    }

    const html = await response.text();
    const parsed = new DOMParser().parseFromString(html, "text/html");
    const shell = parsed.querySelector(".procgen-app > .shell, main.shell");

    if (!shell) {
      throw new Error("Could not find ProcGen widget shell markup.");
    }

    host.replaceChildren(shell);

    const runtimeConfig = {
      mode: "wasm",
      moduleUrl: "/widgets/proc-gen/engine-loader.js",
      search: embedSearch,
      storageKey,
      updateDocumentTitle: false,
    };

    if (window.__procgenInlineShaderVersion !== widgetAssetVersion) {
      window.__procgenInlineShaderPromise = new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = `/widgets/proc-gen/procgen-shaders.js?v=${encodeURIComponent(widgetAssetVersion)}`;
        script.async = false;
        script.onload = resolve;
        script.onerror = reject;
        document.body.appendChild(script);
      });
      window.__procgenInlineShaderVersion = widgetAssetVersion;
    }

    await window.__procgenInlineShaderPromise;

    if (window.__procgenInlineAppSourceVersion !== widgetAssetVersion) {
      window.__procgenInlineAppSourcePromise = fetch(`/widgets/proc-gen/app.js?v=${encodeURIComponent(widgetAssetVersion)}`, {
        cache: "no-store",
      }).then(async (appResponse) => {
        if (!appResponse.ok) {
          throw new Error(`Failed to load ProcGen app script (HTTP ${appResponse.status}).`);
        }

        return appResponse.text();
      });
      window.__procgenInlineAppSourceVersion = widgetAssetVersion;
    }

    window.__procgenInlineMountQueue = (window.__procgenInlineMountQueue || Promise.resolve()).then(async () => {
      const appSource = await window.__procgenInlineAppSourcePromise;
      const baseDocument = document;
      const scopedDocument = new Proxy(baseDocument, {
        get(target, prop) {
          if (prop === "getElementById") {
            return (id) => host.querySelector(`#${id}`);
          }

          if (prop === "querySelector") {
            return (selector) => host.querySelector(selector);
          }

          if (prop === "querySelectorAll") {
            return (selector) => host.querySelectorAll(selector);
          }

          const value = Reflect.get(target, prop, target);
          return typeof value === "function" ? value.bind(target) : value;
        },
      });

      const previousConfig = window.__PROCGEN_APP_CONFIG__;
      window.__PROCGEN_APP_CONFIG__ = runtimeConfig;

      try {
        const mountApp = new Function("document", appSource);
        mountApp(scopedDocument);
      } finally {
        window.__PROCGEN_APP_CONFIG__ = previousConfig;
      }
    });

    await window.__procgenInlineMountQueue;
  })().catch((error) => {
    console.error(error);
  });
</script>
