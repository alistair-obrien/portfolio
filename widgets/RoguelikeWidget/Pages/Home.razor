@using RoguelikeWidget.Services
@inject WidgetSession Session

@{
    var state = Session.State;
    var player = state?.PlayerHUD;
    var maps = state?.Maps ?? [];
    var activeMap = maps.FirstOrDefault(map => map.Characters.Any(character => character.CharacterId == player?.characterUid))
        ?? maps.FirstOrDefault();
    var activeCharacters = activeMap?.Characters?.ToList() ?? [];
}

<PageTitle>Roguelike Widget</PageTitle>

<section class="widget-shell">
    <header class="widget-header">
        <div>
            <p class="eyebrow">Local Browser Session</p>
            <h1>Cyberpunk Roguelike Widget</h1>
            <p class="lede">
                This widget is running the C# engine entirely in the browser. Each embed gets its own isolated session.
            </p>
        </div>
        <button class="reset-button" @onclick="Reset">Reset</button>
    </header>

    @if (!string.IsNullOrWhiteSpace(Session.LastMessage))
    {
        <article class="card feedback-card">
            <p class="lede">@Session.LastMessage</p>
        </article>
    }

    @if (player is not null)
    {
        <div class="status-grid">
            <article class="card">
                <p class="label">Character</p>
                <p class="mono">@player.characterUid</p>
            </article>
            <article class="card">
                <p class="label">Operating System</p>
                <p class="value">@player.OperatingSystemId</p>
            </article>
        </div>
    }

    @if (activeMap is not null)
    {
        <article class="card map-card">
            <div class="map-header">
                <div>
                    <p class="label">Map Id</p>
                    <p class="mono">@activeMap.MapId.Value</p>
                </div>
                <div class="badge">@activeMap.Width x @activeMap.Height</div>
            </div>

            <div class="map-grid" style="@($"grid-template-columns: repeat({activeMap.Width}, minmax(0, 1fr));")">
                @for (var y = 0; y < activeMap.Height; y++)
                {
                    @for (var x = 0; x < activeMap.Width; x++)
                    {
                        var tileX = x;
                        var tileY = y;
                        var occupant = FindOccupant(activeCharacters, tileX, tileY);
                        var isPlayer = occupant?.CharacterId == player?.characterUid;
                        var cssClass = occupant is null
                            ? "cell"
                            : isPlayer
                                ? "cell occupied player"
                                : "cell occupied";
                        var clickClass = isPlayer ? "cell-button current-cell" : "cell-button";
                        var marker = occupant is null ? string.Empty : isPlayer ? "@" : "C";
                        var title = occupant is null
                            ? $"Move to ({tileX}, {tileY})"
                            : isPlayer
                                ? $"You are here: ({tileX}, {tileY})"
                                : $"{occupant.CharacterPresentation?.Name ?? occupant.CharacterId.Value} @ ({tileX}, {tileY})";

                        <button
                            type="button"
                            class="@clickClass"
                            title="@title"
                            @onclick="@(() => MoveToCell(activeMap.MapId, tileX, tileY))">
                            <div class="@cssClass">@marker</div>
                        </button>
                    }
                }
            </div>

            <div class="placements">
                @foreach (var character in activeCharacters)
                {
                    <div class="placement-row">
                        <span>@(character.CharacterPresentation?.Name ?? character.CharacterId.Value)</span>
                        <span class="badge @(character.CharacterId == player?.characterUid ? "player-badge" : string.Empty)">
                            (@character.CellFootprint.X, @character.CellFootprint.Y)
                        </span>
                    </div>
                }
            </div>
        </article>
    }
    else
    {
        <article class="card">
            <p class="lede">No map is loaded in this session.</p>
        </article>
    }
</section>

@code {
    private void Reset()
    {
        Session.Reset();
    }

    private void MoveToCell(MapChunkId mapId, int x, int y)
    {
        Session.MovePlayerToCell(mapId, x, y);
    }

    private static MapCharacterPlacementPresentation? FindOccupant(
        List<MapCharacterPlacementPresentation> characters,
        int x,
        int y)
    {
        return characters.FirstOrDefault(character =>
            x >= character.CellFootprint.X &&
            x < character.CellFootprint.X + character.CellFootprint.Width &&
            y >= character.CellFootprint.Y &&
            y < character.CellFootprint.Y + character.CellFootprint.Height);
    }
}
